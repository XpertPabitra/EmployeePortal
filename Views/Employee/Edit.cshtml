@model EmployeePortal.Models.Domain.Employee

@{
    ViewData["Title"] = "Modify Profile";
    var departments = ViewBag.Departments as IEnumerable<dynamic>;
    var types = ViewBag.EmployeeTypes as IEnumerable<dynamic>;
}

<div class="container mt-5" style="max-width: 800px;">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-dark text-white p-4">
            <h3 class="mb-0 fw-bold"><i class="fas fa-user-edit me-2 text-warning"></i> Modify Profile</h3>
            <p class="text-white-50 small mb-0">Updating records for Employee ID: #@Model.EmployeeId</p>
        </div>

        <div class="card-body p-5 bg-light">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="EmployeeId" />

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Full Name</label>
                        <input asp-for="FullName" class="form-control border-0 shadow-sm" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Email Address</label>
                        <input asp-for="Email" class="form-control border-0 shadow-sm" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Full Name</label>
                        <input asp-for="FullName" class="form-control border-0 shadow-sm" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Department</label>
                        <select asp-for="DepartmentId" class="form-select border-0 shadow-sm">
                            @foreach (var dept in ViewBag.Departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Designation</label>
                        <input asp-for="Designation" class="form-control border-0 shadow-sm" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Department</label>
                        <select asp-for="DepartmentId" class="form-select border-0 shadow-sm">
                            @foreach (var dept in departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Contract Type</label>
                        <select asp-for="EmployeeTypeId" class="form-select border-0 shadow-sm">
                            @foreach (var type in types)
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Monthly Salary</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text border-0 bg-white">₹</span>
                            <input asp-for="Salary" type="number" step="0.01" class="form-control border-0" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Hire Date</label>
                        <input asp-for="HireDate" type="date" class="form-control border-0 shadow-sm" />
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch p-3 bg-white rounded shadow-sm d-flex justify-content-between align-items-center">
                            <label class="form-check-label fw-bold text-dark" for="IsActive">Employment Status Active</label>
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch">
                        </div>
                    </div>
                </div>

                <div class="mt-5 d-flex gap-3">
                    <a asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-outline-secondary w-50 py-3 rounded-pill fw-bold">
                        Discard Changes
                    </a>
                    <button type="submit" class="btn btn-primary w-50 py-3 rounded-pill fw-bold shadow">
                        Update Profile
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>