@model EmployeePortal.Models.Domain.Employee

@{
    ViewData["Title"] = "Onboarding Confirmed";
    var deptName = ViewBag.DepartmentName ?? "N/A";
    var typeName = ViewBag.TypeName ?? "N/A";
}

<style>
    :root {
        --enterprise-navy: #1a1c2c;
        --success-emerald: #27ae60;
        --border-color: #e2e8f0;
        --label-gray: #64748b;
    }

    body {
        background-color: #f8fafc;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    /* Elegant Top Banner */
    .success-hero {
        background-color: var(--enterprise-navy);
        background-image: radial-gradient(circle at 20% 150%, #2c3e50 0%, var(--enterprise-navy) 100%);
        color: white;
        padding: 5rem 2rem 8rem;
        border-radius: 0 0 40px 40px;
        text-align: center;
    }

    .success-icon {
        background: rgba(39, 174, 96, 0.1);
        color: var(--success-emerald);
        width: 100px;
        height: 100px;
        line-height: 100px;
        border-radius: 50%;
        font-size: 3.5rem;
        display: inline-block;
        margin-bottom: 1.5rem;
        border: 2px solid var(--success-emerald);
        animation: fadeIn 1s ease-out;
    }

    /* Refined Card */
    .summary-card {
        background: #ffffff;
        border: 1px solid var(--border-color);
        border-radius: 20px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        margin-top: -6rem;
        margin-bottom: 4rem;
        overflow: hidden;
    }

    .card-content-area {
        padding: 4rem;
    }

    /* Classic Details Styling */
    .info-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--label-gray);
        letter-spacing: 1.2px;
        margin-bottom: 0.4rem;
    }

    .info-value {
        font-size: 1.05rem;
        font-weight: 500;
        color: #0f172a;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        margin-bottom: 1.5rem;
    }

    .section-divider {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--enterprise-navy);
        padding-bottom: 1rem;
        margin-bottom: 2rem;
        border-bottom: 2px solid var(--enterprise-navy);
        width: fit-content;
    }

    /* Audit Alert Box */
    .audit-box {
        background-color: #f1f5f9;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    /* Buttons */
    .btn-action-group .btn {
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-primary {
        background-color: var(--enterprise-navy);
        border: none;
    }

        .btn-primary:hover {
            background-color: #000;
            transform: translateY(-1px);
        }

    .btn-outline-success {
        color: var(--success-emerald);
        border-color: var(--success-emerald);
    }

        .btn-outline-success:hover {
            background-color: var(--success-emerald);
            border-color: var(--success-emerald);
        }
</style>

<div class="success-hero">
    <div class="container" style="max-width: 900px;">
        <div class="success-icon">
            <i class="fas fa-check"></i>
        </div>
        <h1 class="display-5 fw-bold mb-2">Registration Confirmed</h1>
        <p class="lead opacity-75">The employee profile has been successfully indexed in the corporate directory.</p>
    </div>
</div>

<div class="container" style="max-width: 850px;">
    <div class="card summary-card shadow-sm">
        <div class="card-content-area">

            <div class="d-flex justify-content-between align-items-end mb-5">
                <div>
                    <span class="text-muted small">Employee Name</span>
                    <h2 class="fw-bold mb-0">@Model.FullName</h2>
                </div>
                <div class="text-end">
                    <span class="badge bg-success-subtle text-success px-3 py-2 border border-success-subtle">
                        <i class="fas fa-check-circle me-1"></i> RECORD ACTIVE
                    </span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 pe-md-5">
                    <div class="section-divider">Profile Details</div>

                    <div class="info-label">Corporate Email</div>
                    <div class="info-value">@Model.Email</div>

                    <div class="info-label">Designation</div>
                    <div class="info-value">@Model.Designation</div>

                    <div class="info-label">Division</div>
                    <div class="info-value">@deptName</div>

                    <div class="info-label">Hire Date</div>
                    <div class="info-value">@Model.HireDate.ToString("MMMM dd, yyyy")</div>
                </div>

                <div class="col-md-6 ps-md-5">
                    <div class="section-divider">Contract Metrics</div>

                    <div class="info-label">Employee System ID</div>
                    <div class="info-value text-primary fw-bold">ID_@Model.EmployeeId.ToString("D4")</div>

                    <div class="info-label">Contract Type</div>
                    <div class="info-value">@typeName</div>

                    <div class="info-label">Base Compensation</div>
                    <div class="info-value text-success">₹ @Model.Salary.ToString("N2")</div>

                    <div class="info-label">Contact Reference</div>
                    <div class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "Not Specified" : Model.Phone)</div>
                </div>
            </div>

            <div class="audit-box mt-4">
                <i class="fas fa-shield-alt text-muted fa-lg"></i>
                <p class="mb-0 small text-muted">
                    <strong>Audit Integrity:</strong> This transaction was authenticated and logged by the system administrator. A digital footprint of this record has been archived for compliance.
                </p>
            </div>

            <div class="text-center mt-5 pt-4 border-top btn-action-group">
                <a asp-action="Create" class="btn btn-outline-success me-3">
                    <i class="fas fa-user-plus me-2"></i> Register Another
                </a>
                <a asp-action="Index" class="btn btn-primary shadow-sm">
                    <i class="fas fa-th-list me-2"></i> Back to Directory
                </a>
            </div>
        </div>
    </div>

    <div class="text-center text-muted mb-5">
        <p class="small text-uppercase ls-wide">© 2026 Enterprise Resource Management System</p>
    </div>
</div>