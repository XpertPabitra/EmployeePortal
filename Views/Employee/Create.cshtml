@model EmployeePortal.Models.Domain.Employee

@{
    ViewData["Title"] = "Create Employee";
    var departments = ViewBag.Departments as IEnumerable<dynamic>;
    var types = ViewBag.EmployeeTypes as IEnumerable<dynamic>;
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h3 class="mb-0"><i class="fas fa-user-plus"></i> Register New Employee</h3>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="text-primary border-bottom pb-2 mb-3">Personal Details</h5>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="john@company.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label fw-bold">Phone Number</label>
                            <input asp-for="Phone" class="form-control" placeholder="+1234567890" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gender" class="form-label fw-bold">Gender</label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">Select Gender</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DateOfBirth" class="form-label fw-bold">Date of Birth</label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="text-primary border-bottom pb-2 mb-3">Employment Details</h5>

                        <div class="mb-3">
                            <label asp-for="Designation" class="form-label fw-bold">Designation</label>
                            <input asp-for="Designation" class="form-control" placeholder="e.g. Senior Developer" />
                            <span asp-validation-for="Designation" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DepartmentId" class="form-label fw-bold">Department</label>
                                <select asp-for="DepartmentId" class="form-select">
                                    <option value="">-- Select Dept --</option>
                                    @if (departments != null)
                                    {
                                        foreach (var dept in departments)
                                        {
                                            <option value="@dept.Id">@dept.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EmployeeTypeId" class="form-label fw-bold">Employee Type</label>
                                <select asp-for="EmployeeTypeId" class="form-select">
                                    <option value="">-- Select Type --</option>
                                    @if (types != null)
                                    {
                                        foreach (var t in types)
                                        {
                                            <option value="@t.Id">@t.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="EmployeeTypeId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="HireDate" class="form-label fw-bold">Hire Date</label>
                                <input asp-for="HireDate" type="date" class="form-control" />
                                <span asp-validation-for="HireDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Salary" class="form-label fw-bold">Salary (₹)</label>
                                <input asp-for="Salary" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                <span asp-validation-for="Salary" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3 form-check mt-4">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label fw-bold" asp-for="IsActive">
                                Currently Active
                            </label>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-success btn-lg px-5">
                        <i class="fas fa-save"></i> Save Employee
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}