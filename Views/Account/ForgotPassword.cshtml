@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>System Recovery | ERMS Portal</title>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --brand-navy: #0f172a;
            --brand-gold: #c5a059;
            --slate-border: #e2e8f0;
            --soft-bg: #f8fafc;
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--soft-bg);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .recovery-container {
            width: 100%;
            max-width: 440px;
            padding: 20px;
        }

        .recovery-card {
            background: #ffffff;
            padding: 3.5rem 2.5rem;
            border-radius: 16px;
            border: 1px solid var(--slate-border);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
            text-align: center;
        }

        .brand-icon-wrapper {
            width: 64px;
            height: 64px;
            background: var(--brand-navy);
            color: var(--brand-gold);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 2rem;
            transform: rotate(-5deg);
            box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.2);
        }

        .recovery-title {
            font-weight: 800;
            color: var(--brand-navy);
            letter-spacing: -0.5px;
            margin-bottom: 0.5rem;
        }

        .recovery-subtitle {
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 2.5rem;
            line-height: 1.5;
        }

        .form-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #475569;
            margin-bottom: 0.6rem;
            display: block;
            text-align: left;
        }

        .input-group-custom {
            position: relative;
            display: flex;
            align-items: center;
        }

            .input-group-custom i {
                position: absolute;
                left: 1rem;
                color: #94a3b8;
                font-size: 1.1rem;
                pointer-events: none;
            }

        .form-control-ent {
            width: 100%;
            padding: 0.85rem 1rem 0.85rem 2.8rem;
            border: 1.5px solid var(--slate-border);
            border-radius: 10px;
            background: #ffffff;
            transition: all 0.2s;
            font-weight: 500;
            font-size: 0.95rem;
        }

            .form-control-ent:focus {
                outline: none;
                border-color: var(--brand-navy);
                box-shadow: 0 0 0 4px rgba(15, 23, 42, 0.05);
            }

        .btn-ent {
            background: var(--brand-navy);
            color: white;
            border: none;
            width: 100%;
            padding: 1rem;
            border-radius: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s;
            margin-top: 0.5rem;
        }

            .btn-ent:hover {
                background: #000000;
                transform: translateY(-1px);
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            }

        .alert-success-ent {
            background: #f0fdf4;
            border-left: 4px solid #22c55e;
            color: #166534;
            padding: 1.25rem;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-bottom: 2rem;
            text-align: left;
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            text-decoration: none;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            transition: color 0.2s;
            margin-top: 2rem;
        }

            .back-link:hover {
                color: var(--brand-navy);
            }

            .back-link i {
                margin-right: 8px;
                font-size: 0.75rem;
            }
    </style>
</head>
<body>

    <div class="recovery-container">
        <div class="recovery-card animate__animated animate__fadeInUp">

            <div class="brand-icon-wrapper">
                <i class="fas fa-shield-alt"></i>
            </div>

            <h2 class="recovery-title">Account Recovery</h2>
            <p class="recovery-subtitle">
                Enter your administrative email address to initialize the secure recovery protocol.
            </p>

            @if (ViewBag.Message != null)
            {
                <div class="alert-success-ent animate__animated animate__fadeIn">
                    <i class="fas fa-check-circle mt-1"></i>
                    <span>@ViewBag.Message</span>
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                <div class="mb-4 text-start">
                    <label class="form-label">Work Email Address</label>
                    <div class="input-group-custom">
                        <i class="fas fa-envelope"></i>
                        <input type="email" name="email" class="form-control-ent" placeholder="admin@enterprise.com" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-ent">
                    Send Recovery Link <i class="fas fa-chevron-right ms-2 small"></i>
                </button>
            </form>

            <a asp-action="Login" asp-controller="Account" class="back-link">
                <i class="fas fa-arrow-left"></i> Return to Secure Login
            </a>

            <div class="mt-5 pt-3 border-top">
                <p class="text-uppercase tracking-widest text-muted mb-0" style="font-size: 0.6rem; opacity: 0.6;">
                    System Node: @Environment.MachineName.ToUpper()
                </p>
            </div>
        </div>
    </div>

</body>
</html>