@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Credentials | ERMS Portal</title>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --ent-navy: #0f172a;
            --ent-accent: #c5a059;
            --ent-border: #e2e8f0;
            --soft-slate: #f8fafc;
        }

        body {
            background-color: var(--soft-slate);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .reset-card {
            background: white;
            padding: 3.5rem;
            border-radius: 20px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 450px;
            border: 1px solid var(--ent-border);
        }

        .brand-icon {
            width: 60px;
            height: 60px;
            background: var(--ent-navy);
            color: var(--ent-accent);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-label-caps {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #64748b;
            margin-bottom: 0.5rem;
            display: block;
        }

        .form-control-ent {
            width: 100%;
            padding: 0.85rem 1rem;
            border: 1.5px solid var(--ent-border);
            border-radius: 10px;
            background: var(--soft-slate);
            transition: all 0.2s;
        }

            .form-control-ent:focus {
                outline: none;
                border-color: var(--ent-navy);
                background: white;
                box-shadow: 0 0 0 4px rgba(15, 23, 42, 0.06);
            }

        .btn-authorize {
            background: var(--ent-navy);
            color: white;
            border: none;
            width: 100%;
            padding: 1rem;
            border-radius: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 1.5rem;
            transition: all 0.3s;
        }

            .btn-authorize:hover {
                background: #000;
                transform: translateY(-2px);
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            }
    </style>
</head>
<body>

    <div class="reset-card animate__animated animate__fadeInUp">
        <div class="brand-icon">
            <i class="fas fa-user-shield"></i>
        </div>

        <h2 class="fw-800 mb-1" style="letter-spacing: -1px;">Secure Reset</h2>
        <p class="text-muted small mb-4">Update your administrative credentials for node access.</p>

        <form asp-action="ResetPassword" asp-controller="Account" method="post">
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <div class="mb-3">
                <label class="form-label-caps">New Passcode</label>
                <input type="password" name="newPassword" class="form-control-ent" placeholder="••••••••" required autofocus />
            </div>

            <div class="mb-4">
                <label class="form-label-caps">Confirm Passcode</label>
                <input type="password" class="form-control-ent" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn btn-authorize">
                Update Credentials <i class="fas fa-check-double ms-2"></i>
            </button>
        </form>
    </div>

</body>
</html>