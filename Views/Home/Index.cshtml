@model List<EmployeePortal.Models.Domain.Employee>

@{
    ViewData["Title"] = "Executive Dashboard";
    var departments = ViewBag.Departments as IEnumerable<dynamic>;
    var types = ViewBag.EmployeeTypes as IEnumerable<dynamic>;

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 5;
    int totalRecords = ViewBag.TotalRecords ?? 0;
}

<style>
    :root {
        --p-dark: #1a1c2c;
        --p-gold: #c5a059;
        --p-blue: #2c3e50;
        --p-border: #e2e8f0;
    }

    body {
        background-color: #f8fafc;
        font-family: 'Inter', sans-serif;
    }

    /* 1. Header with Glassmorphism shadow */
    .main-header {
        background: linear-gradient(135deg, var(--p-dark) 0%, var(--p-blue) 100%);
        color: white;
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    /* 2. Compact Filter Section */
    .filter-section {
        background: white;
        border-radius: 15px;
        border: 1px solid var(--p-border);
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .form-label-custom {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #94a3b8;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }

    /* 3. Table Integrity */
    .table-card {
        background: white;
        border-radius: 15px;
        border: 1px solid var(--p-border);
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .table thead {
        background-color: var(--p-dark);
        color: var(--p-gold);
        border-bottom: 2px solid var(--p-gold);
    }

        .table thead th {
            border: none;
            padding: 1.2rem 1rem;
            font-size: 0.75rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

    .custom-badge {
        padding: 0.4em 1em;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.65rem;
        text-transform: uppercase;
        border: 1px solid var(--p-border);
    }

    .action-btn-group .btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: 0.2s;
        background: #f8fafc;
        border: 1px solid var(--p-border);
        color: #64748b;
    }

        .action-btn-group .btn:hover {
            transform: translateY(-2px);
            background: var(--p-dark);
            color: var(--p-gold);
        }
</style>

<div class="container-fluid px-4 mt-4">

    <div class="main-header d-flex flex-wrap justify-content-between align-items-center animate__animated animate__fadeIn">
        <div class="mb-3 mb-md-0">
            <h2 class="fw-bold mb-0"><i class="fas fa-layer-group me-2"></i>Staff Directory</h2>
            <p class="mb-0 opacity-75 small text-uppercase tracking-widest">Enterprise Resource Infrastructure</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="text-end me-2 d-none d-sm-block">
                <span class="d-block small opacity-75">Total Records</span>
                <span class="fw-bold h5 mb-0">@totalRecords</span>
            </div>
            <a asp-action="Create" class="btn btn-warning fw-bold text-dark px-4 shadow-sm" style="background-color: var(--p-gold); border:none; border-radius:10px;">
                <i class="fas fa-user-plus me-1"></i> Add Employee
            </a>
        </div>
    </div>

    <div class="filter-section shadow-sm">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-lg-3 col-md-6">
                    <label class="form-label-custom">Personnel Search</label>
                    <input type="text" name="searchName" value="@ViewData["CurrentFilter"]" class="form-control bg-light border-0" style="padding: 0.6rem;" placeholder="Search name or email...">
                </div>
                <div class="col-lg-2 col-md-6">
                    <label class="form-label-custom">Division</label>
                    <select name="deptId" class="form-select bg-light border-0" style="padding: 0.6rem;">
                        <option value="">All Departments</option>
                        @foreach (var d in departments)
                        {
                            <option value="@d.Id" selected="@(d.Id == (int?)ViewBag.SelectedDept)">@d.Name</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-6">
                    <label class="form-label-custom">Status</label>
                    <select name="typeId" class="form-select bg-light border-0" style="padding: 0.6rem;">
                        <option value="">All Types</option>
                        @foreach (var t in types)
                        {
                            <option value="@t.Id" selected="@(t.Id == (int?)ViewBag.SelectedType)">@t.Name</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-6">
                    <label class="form-label-custom">Display</label>
                    <input type="number" name="itemsPerPage" class="form-control bg-light border-0" value="@pageSize" style="padding: 0.6rem;">
                </div>
                <div class="col-lg-3 col-md-12">
                    <button type="submit" class="btn btn-dark w-100 fw-bold py-2" style="border-radius:10px;">
                        <i class="fas fa-sliders-h me-2"></i>Apply Filters
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="table-card shadow-sm animate__animated animate__fadeInUp">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Employee Identity</th>
                        <th>Position</th>
                        <th>Division</th>
                        <th>Contract</th>
                        <th>Compensation</th>
                        <th>Status</th>
                        <th class="text-center">Operations</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var emp in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@emp.FullName</div>
                                    <div class="text-muted" style="font-size:0.75rem;"><i class="fas fa-envelope me-1"></i>@emp.Email</div>
                                </td>
                                <td>
                                    <div class="fw-bold small">@emp.Designation</div>
                                    <div class="text-muted" style="font-size:0.65rem;">Hired: @emp.HireDate.ToString("dd MMM yyyy")</div>
                                </td>
                                <td><span class="custom-badge bg-light text-primary">@(departments?.FirstOrDefault(d => d.Id == emp.DepartmentId)?.Name)</span></td>
                                <td><span class="custom-badge bg-light text-dark">@(types?.FirstOrDefault(t => t.Id == emp.EmployeeTypeId)?.Name)</span></td>
                                <td class="fw-bold text-dark">₹ @emp.Salary.ToString("N0")</td>
                                <td>
                                    @if (emp.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 rounded-pill">Active</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-danger-subtle text-danger px-3 rounded-pill">Inactive</span>
                                    }
                                </td>
                                <td class="text-center action-btn-group">
                                    <a asp-action="Edit" asp-route-id="@emp.EmployeeId" class="btn" title="Modify"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@emp.EmployeeId" class="btn" onclick="return confirm('Authorize Security Purge?')" title="Purge"><i class="fas fa-trash-alt"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="fas fa-search-minus fa-3x text-muted mb-3 opacity-25"></i>
                                <h4 class="text-muted fw-bold">No Personnel Found</h4>
                                <p class="text-muted small">No data matches your current search parameters.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <nav class="my-5">
        <ul class="pagination justify-content-center">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link border-0 shadow-sm mx-1 rounded text-dark" href="?page=1&searchName=@ViewData["CurrentFilter"]&deptId=@ViewBag.SelectedDept&typeId=@ViewBag.SelectedType">First</a>
                </li>
            }
            <li class="page-item active">
                <span class="page-link border-0 shadow-sm mx-1 rounded bg-dark text-white">@currentPage</span>
            </li>
            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link border-0 shadow-sm mx-1 rounded text-dark" href="?page=@totalPages&searchName=@ViewData["CurrentFilter"]&deptId=@ViewBag.SelectedDept&typeId=@ViewBag.SelectedType">Last</a>
                </li>
            }
        </ul>
        <p class="text-center text-muted small mt-2">Inventory Node @currentPage of @totalPages</p>
    </nav>
</div>